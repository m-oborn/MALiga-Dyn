# Sleeper Fantasy Football Configuration
# Copy this file to .env and fill in your actual values

# Your Sleeper league ID (find this in your league URL)
# Example: https://sleeper.app/leagues/1335689534179926016/league
SLEEPER_LEAGUE_ID=1335689534179926016

# Optional: Set default week (otherwise uses 'auto' for current week)
# SLEEPER_DEFAULT_WEEK=1

# Optional: Enable verbose logging by default
# VERBOSE=true
